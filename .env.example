### LLM provider configuration (choose one)
# Preferred:
# HARUNAI_PROVIDER=openrouter
# HARUNAI_MODEL=deepseek/deepseek-chat-v3.1
#
# Also supported:
# AI_PROVIDER=openrouter
# OPENROUTER_MODEL=deepseek/deepseek-chat-v3.1

### Provider API keys (set the one matching your provider)
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

### Optional OpenRouter headers
# OPENROUTER_HTTP_REFERER=
# OPENROUTER_X_TITLE=
# OPENROUTER_BASE_URL=

### Optional assistant timeout (ms)
# HARUNAI_TIMEOUT_MS=45000

### Telegram delivery (required for send_telegram)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# HarunAI (development)

# Choose provider/model for the integrated Assistant Agent.
# - openai (default), openrouter, anthropic, google, etc.
HARUNAI_PROVIDER=openrouter
HARUNAI_MODEL=deepseek/deepseek-chat-v3.1

# OpenRouter
OPENROUTER_API_KEY=replace_me
OPENROUTER_HTTP_REFERER=http://localhost
OPENROUTER_X_TITLE=HarunAI

# OpenAI (if using HARUNAI_PROVIDER=openai)
# OPENAI_API_KEY=replace_me

