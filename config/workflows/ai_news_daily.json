{
  "name": "ai_news_daily",
  "description": "Fetch AI news, summarize, and send to Telegram.",
  "steps": [
    {
      "id": "fetch",
      "agent": "assistant",
      "input_schema": {
        "type": "object",
        "properties": {
          "task": {
            "type": "string",
            "description": "The task to perform"
          }
        }
      },
      "output_ref": "news"
    },
    {
      "id": "distribute",
      "agent": "distribution_agent",
      "input_schema": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "The message to send via Telegram"
          }
        },
        "required": ["message"]
      }
    }
  ]
}
