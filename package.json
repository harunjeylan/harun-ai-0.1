{
  "name": "harunai",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Personal AI Operations System (CLI, multi-agent, workflow-driven).",
  "bin": {
    "harunai": "./src/cli.ts"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "bun build src/cli.ts --outdir dist --target bun",
    "start": "bun run dist/cli.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@mariozechner/pi-agent-core": "^0.58.4",
    "@mariozechner/pi-ai": "^0.58.4",
    "@mariozechner/pi-coding-agent": "^0.58.4",
    "@mariozechner/pi-mom": "^0.58.4",
    "@mariozechner/pi-tui": "^0.58.4",
    "chalk": "^5.4.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2"
  }
}
